{
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:8787"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/copel/AppData/Local/Packages/PythonSoftwareFoundation.Python.3.11_qbz5n2kfra8p0/LocalCache/local-packages/Python311/Scripts/headroom.EXE init hook ensure --profile init-video-analyzer-repo-bfa81d4d --marker headroom-init-claude",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/copel/AppData/Local/Packages/PythonSoftwareFoundation.Python.3.11_qbz5n2kfra8p0/LocalCache/local-packages/Python311/Scripts/headroom.EXE init hook ensure --profile init-video-analyzer-repo-bfa81d4d --marker headroom-init-claude",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "headroom@headroom-marketplace": true
  }
}
